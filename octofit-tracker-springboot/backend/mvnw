#!/bin/sh
# Maven Wrapper startup script for Unix-based systems

set -e

MAVEN_PROJECTBASEDIR="${MAVEN_BASEDIR:-${BASEDIR}}"
MAVEN_WRAPPER_JAR="${MAVEN_PROJECTBASEDIR}/.mvn/wrapper/maven-wrapper.jar"
MAVEN_WRAPPER_PROPERTIES="${MAVEN_PROJECTBASEDIR}/.mvn/wrapper/maven-wrapper.properties"

# Use Maven from wrapper if it exists, otherwise fall back to system Maven
if [ -r "$MAVEN_WRAPPER_JAR" ]; then
    MAVEN_CMD="java"
    if [ -n "$JAVA_HOME" ]; then
        MAVEN_CMD="$JAVA_HOME/bin/java"
    fi
    
    exec "$MAVEN_CMD" \
        -classpath "$MAVEN_WRAPPER_JAR" \
        "-Dmaven.multiModuleProjectDirectory=$MAVEN_PROJECTBASEDIR" \
        org.apache.maven.wrapper.MavenWrapperMain "$@"
else
    echo "Error: Maven Wrapper JAR not found. Please run 'mvn -N wrapper:wrapper' first."
    exit 1
fi
